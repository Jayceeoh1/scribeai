{
  "$schema": "https://schema.railpack.com",
  "buildAptPackages": ["curl", "ca-certificates", "python3", "python3-pip", "python3-venv", "git", "unzip"],
  "steps": {
    "install-ytdlp": {
      "inputs": [{ "step": "packages:mise" }],
      "commands": [
        "mkdir -p /opt/ytdlp-env",
        "python3 -m venv /opt/ytdlp-env",
        "/opt/ytdlp-env/bin/pip install --no-cache-dir -U yt-dlp bgutil-ytdlp-pot-provider",
        "mkdir -p /usr/local/bin",
        "ln -sf /opt/ytdlp-env/bin/yt-dlp /usr/local/bin/yt-dlp",
        "mkdir -p /opt/deno",
        "curl -fsSL https://dl.deno.land/release-latest.txt -o /tmp/deno-version.txt",
        "curl -fsSL -o /tmp/deno.zip https://dl.deno.land/release/v2.9.0/deno-x86_64-unknown-linux-gnu.zip",
        "unzip -o /tmp/deno.zip -d /opt/deno",
        "chmod a+rx /opt/deno/deno",
        "ln -sf /opt/deno/deno /usr/local/bin/deno",
        "/usr/local/bin/deno --version",
        "/usr/local/bin/yt-dlp --version",
        "git clone --depth 1 --single-branch --branch 1.3.1 https://github.com/Brainicism/bgutil-ytdlp-pot-provider.git /opt/bgutil-server",
        "cd /opt/bgutil-server/server && npm ci && npx tsc"
      ],
      "deployOutputs": [
        { "include": ["/usr/local/bin/yt-dlp", "/usr/local/bin/deno", "/opt/ytdlp-env", "/opt/bgutil-server", "/opt/deno"] }
      ]
    }
  },
  "deploy": {
    "aptPackages": ["ffmpeg", "ca-certificates", "python3"]
  }
}
