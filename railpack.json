{
  "$schema": "https://schema.railpack.com",
  "buildAptPackages": ["curl", "ca-certificates", "python3", "python3-pip", "python3-venv", "git"],
  "steps": {
    "install-ytdlp": {
      "inputs": [{ "step": "packages:mise" }],
      "commands": [
        "mkdir -p /opt/ytdlp-env",
        "python3 -m venv /opt/ytdlp-env",
        "/opt/ytdlp-env/bin/pip install --no-cache-dir -U yt-dlp bgutil-ytdlp-pot-provider",
        "mkdir -p /usr/local/bin",
        "ln -sf /opt/ytdlp-env/bin/yt-dlp /usr/local/bin/yt-dlp",
        "/usr/local/bin/yt-dlp --version",
        "git clone --depth 1 --single-branch --branch 1.3.1 https://github.com/Brainicism/bgutil-ytdlp-pot-provider.git /opt/bgutil-server",
        "cd /opt/bgutil-server/server && npm ci && npx tsc"
      ],
      "deployOutputs": [
        { "include": ["/usr/local/bin/yt-dlp", "/opt/ytdlp-env", "/opt/bgutil-server"] }
      ]
    }
  },
  "deploy": {
    "aptPackages": ["ffmpeg", "ca-certificates", "python3"]
  }
}
